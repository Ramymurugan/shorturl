# Set default behavior to automatically normalize line endings.
# Git will handle text files by converting CRLF to LF on commit.
* text=auto

# Explicitly declare text files to ensure they are normalized.
*.js text
*.jsx text
*.json text
*.css text
*.html text
*.md text
*.svg text

# These files should always have LF line endings, even on Windows.
*.sh eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary